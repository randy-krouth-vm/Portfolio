        <mxCell id="1p7aTPJoerzvOReT1d6R-246" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;" value="&lt;div&gt;&lt;div&gt;Example: OpenSSL&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="168.5" x="1107" y="879.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="1p7aTPJoerzvOReT1d6R-247" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;container=0;" value="Enclave is an optional confidential compute enhancement based on environment.&amp;nbsp;" vertex="1">
          <mxGeometry height="68" width="271.43" x="3" y="798.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="1p7aTPJoerzvOReT1d6R-248" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;container=0;" value="By utilizing Kerberos, LDAP, or SCRAM-SHA-256 user/ service authentication, where the public key certificate (mTLS) model provides device and network-level protection.&amp;nbsp;Mutual TLS (mTLS) extends HTTPS by enforcing client and server certificate authentication, providing device/service identity and limiting lateral movement." vertex="1">
          <mxGeometry height="68" width="322" x="589.9300000000003" y="617.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="1p7aTPJoerzvOReT1d6R-250" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;" value="&lt;div&gt;&lt;div&gt;Rate Limit&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="183" x="682" y="826.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="1p7aTPJoerzvOReT1d6R-258" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;container=0;" value="Kerberos, LDAP, Scram-Sha-256 used to provide protection against stored environment variables if containers are compromised. Therefore providing additional security against runtime exploits." vertex="1">
          <mxGeometry height="68" width="322" x="346.47000000000116" y="1033" as="geometry" />
        </mxCell>
        <mxCell id="1p7aTPJoerzvOReT1d6R-259" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;container=0;" value="The majority of database platforms are limited to transport-level authentication (mTLS) combined with a single user/service authentication method. Architectures that support independent, layered authentication controls can provide stronger defense-in-depth and better alignment with zero-trust principles." vertex="1">
          <mxGeometry height="68" width="322" x="1694" y="711.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="1p7aTPJoerzvOReT1d6R-260" parent="fjQrz3hnMPhjCWTDFtm6-51" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FFFFFF;container=0;" value="&lt;span data-path-to-node=&quot;5,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;&quot;&gt;Certificate CN Mapping Example:&lt;/span&gt; Configure PostgreSQL (via &lt;code data-path-to-node=&quot;5,0,0&quot; data-index-in-node=&quot;50&quot;&gt;pg_ident.conf&lt;/code&gt;) so that the database username &lt;b data-path-to-node=&quot;5,0,0&quot; data-index-in-node=&quot;95&quot;&gt;must&lt;/b&gt; match the Common Name (CN) inside the certificate. This ensures that an attacker with &quot;Password A&quot; cannot use &quot;Certificate B&quot; to get in." vertex="1">
          <mxGeometry height="68" width="322" x="65" y="316.9999999999999" as="geometry" />
        </mxCell>
        <mxCell id="AbWnczve7ZLlayRRT3CC-9" edge="1" parent="fjQrz3hnMPhjCWTDFtm6-51" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeColor=#FFFFFF;strokeWidth=2;" value="">
